generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  name           String?
  isAdmin        Boolean         @default(false)
  plan           String          @default("free") // free | monthly | yearly
  planStarted    DateTime?
  trialEndsAt    DateTime?
  blocked        Boolean         @default(false)
  createdAt      DateTime        @default(now())
  agents         Agent[]
  invoices       Invoice[]
  contacts       Contact[]
  scheduledPosts  ScheduledPost[]
  scheduledEmails ScheduledEmail[]
  settings       UserSettings?
  tasks          Task[]
  accessGiven    TeamAccess[] @relation("OwnerAccess")
  accessReceived TeamAccess[] @relation("CollaboratorAccess")
  businesses     Business[]
  features       UserFeature[]
  staff          Staff[]
  surveys        Survey[]
  inventory      InventoryItem[]
  giftCards      GiftCard[]
  bundles        Bundle[]
  waitlist       WaitlistEntry[]
}

model UserFeature {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug      String
  createdAt DateTime @default(now())
  @@unique([userId, slug])
}

model Business {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())

  contacts        Contact[]
  invoices        Invoice[]
  scheduledEmails ScheduledEmail[]
  scheduledPosts  ScheduledPost[]
}

model TeamAccess {
  id                String   @id @default(cuid())
  ownerId           String
  owner             User     @relation("OwnerAccess", fields: [ownerId], references: [id], onDelete: Cascade)
  collaboratorEmail String
  collaboratorId    String?
  collaborator      User?    @relation("CollaboratorAccess", fields: [collaboratorId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@unique([ownerId, collaboratorEmail])
}

model Task {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     String
  dueTime     String?
  completed   Boolean  @default(false)
  category    String   @default("task")
  createdAt   DateTime @default(now())
}

model UserSettings {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName    String  @default("")
  businessDesc    String  @default("")
  telegramToken   String  @default("")
  telegramChannel String  @default("")
  tiktokHandle    String  @default("")
  contentTone     String  @default("professional")
  autoNurtureOnLead      Boolean @default(false)
  autoReplyOnLeadCapture Boolean @default(false)
  emailFrom       String  @default("")
  emailPassword   String  @default("")
  receptionistName        String  @default("Assistant")
  receptionistHours       String  @default("")
  receptionistServices    String  @default("")
  receptionistBookingLink String  @default("")
  receptionistEnabled     Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Agent {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  instructions  String         @default("You are a helpful assistant.")
  greeting      String         @default("Hello! How can I help you today?")
  model         String         @default("gemini-2.0-flash")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
}

model Conversation {
  id        String    @id @default(cuid())
  agentId   String
  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  sessionId String    @default(cuid())
  createdAt DateTime  @default(now())
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  createdAt      DateTime     @default(now())
}

model Invoice {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId    String?
  business      Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoiceNumber String
  clientName    String
  clientEmail   String
  items         String   // JSON: [{description, quantity, unitPrice}]
  subtotal      Float
  tax           Float    @default(0)
  total         Float
  currency      String   @default("USD")
  status        String   @default("draft") // draft | sent | paid
  dueDate       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  company   String?
  status        String   @default("lead") // lead | customer | lost
  notes         String?
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Staff {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  role      String   @default("")
  email     String?
  phone     String?
  createdAt DateTime @default(now())
}

model Survey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  questions String
  responses String   @default("[]")
  createdAt DateTime @default(now())
}

model InventoryItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  quantity  Int      @default(0)
  unit      String   @default("")
  lowAlert  Int      @default(5)
  createdAt DateTime @default(now())
}

model GiftCard {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  amount    Float
  used      Boolean  @default(false)
  recipient String   @default("")
  createdAt DateTime @default(now())
}

model Bundle {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String   @default("")
  services    String
  price       Float
  createdAt   DateTime @default(now())
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  service   String   @default("")
  status    String   @default("waiting")
  createdAt DateTime @default(now())
}

model ScheduledPost {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId  String?
  business    Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  platform    String   @default("telegram")
  content     String
  imageData   String?  // base64 data URL of an attached product photo
  scheduledAt DateTime
  status      String   @default("pending") // pending | sent | failed
  createdAt   DateTime @default(now())
}

model ScheduledEmail {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId  String?
  business    Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  to          String
  subject     String
  body        String
  scheduledAt DateTime
  status      String   @default("pending") // pending | sent | failed
  label       String?  // e.g. "Day 3 follow-up"
  createdAt   DateTime @default(now())
}
